# Cervantes - Configuration
# Copy this file to .env and fill in your values

# AI Provider Chain (checked in order: openai → gemini → groq → templates)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# AI Configuration
AI_PROVIDER=auto
AI_MODEL=
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Server
PORT=3001
DATABASE_URL=file:../storage/cervantes.db
